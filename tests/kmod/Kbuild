# Kbuild for kh_test.ko (Mode C — standard kernel build)
#
# Usage:
#   make -C /lib/modules/$(uname -r)/build M=$(pwd) modules
#   make -C /path/to/kernel M=$(pwd) ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- modules
#
# For Android kernel headers:
#   make -C /path/to/android-kernel/out/common M=$(pwd) ARCH=arm64 \
#        CROSS_COMPILE=aarch64-linux-gnu- modules

# kbuild resolves -y entries relative to $(src). Use relative paths, not
# $(src)/.. which produces doubled absolute paths in out-of-tree builds.
# See kmod/Kbuild for the same pattern and rationale.

obj-m := kh_test.o
kh_test-y := test_main.o test_hook_kernel.o demo_kh_root.o \
    mem_ops.o log.o transit_setup.o plt_stub.o \
    test_resolver_swapper_pg_dir.o \
    test_resolver_kimage_voffset.o \
    ../../src/hook.o \
    ../../src/memory.o \
    ../../src/symbol.o \
    ../../src/arch/arm64/inline.o \
    ../../src/arch/arm64/transit.o \
    ../../src/arch/arm64/insn.o \
    ../../src/arch/arm64/pgtable.o \
    ../../src/platform/syscall.o \
    ../../src/uaccess.o \
    ../../src/sync.o \
    ../../src/kh_strategy.o \
    ../../src/strategies/swapper_pg_dir.o \
    ../../src/strategies/kimage_voffset.o

ccflags-y := -I$(src)/../../include -I$(src)/../../include/arch/arm64 -I$(src) \
             -Wno-declaration-after-statement \
             -Wno-unknown-sanitizers \
             -Wno-gcc-compat
